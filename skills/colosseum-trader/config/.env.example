# Colosseum Trader - Environment Configuration
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git - it's in .gitignore by default

# =============================================================================
# SOLANA CONFIGURATION
# =============================================================================

# RPC Endpoints (use private endpoints for production)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
# Alternative: Helius, QuickNode, Alchemy
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# Jupiter API (optional but recommended for better rates)
JUPITER_API_KEY=your_jupiter_api_key_here
JUPITER_API_BASE=https://quote-api.jup.ag/v6

# Birdeye API for market data
BIRDEYE_API_KEY=your_birdeye_api_key_here

# Solscan API for analytics
SOLSCAN_API_KEY=your_solscan_api_key_here

# Trading Wallet (64-character base58 private key)
# WARNING: This wallet will execute trades. Keep minimal funds for safety.
SOLANA_TRADING_WALLET_PRIVATE_KEY=your_private_key_here_base58_encoded

# Fee Wallet (separate wallet for transaction fees)
SOLANA_FEE_WALLET_PRIVATE_KEY=your_fee_wallet_private_key_here

# =============================================================================
# ETHEREUM CONFIGURATION
# =============================================================================

# RPC Endpoints
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETHEREUM_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Alternative: Infura, QuickNode, Ankr
# ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# Etherscan API (for contract verification and data)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Alchemy API (if using Alchemy)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Trading Wallet (64-character hex private key, 0x prefix optional)
# WARNING: This wallet will execute trades. Keep minimal funds for safety.
ETHEREUM_TRADING_WALLET_PRIVATE_KEY=0x_your_private_key_here_64_chars

# =============================================================================
# LAYER 2 CONFIGURATION
# =============================================================================

# Base (Coinbase L2)
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_TRADING_WALLET_PRIVATE_KEY=0x_your_private_key_here

# Arbitrum
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_TRADING_WALLET_PRIVATE_KEY=0x_your_private_key_here

# Optimism
OPTIMISM_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_TRADING_WALLET_PRIVATE_KEY=0x_your_private_key_here

# =============================================================================
# DEX APIs
# =============================================================================

# Uniswap (The Graph)
THE_GRAPH_API_KEY=your_graph_api_key_here
UNISWAP_SUBGRAPH=https://gateway.thegraph.com/api/[API_KEY]/subgraphs/id/5zvR82QoaXYFyDEKLZ9t6v9adgnptxYpKpSbxtgVENFV

# Curve Finance
CURVE_API_KEY=your_curve_api_key_here

# 1inch API (for routing)
ONEINCH_API_KEY=your_1inch_api_key_here
ONEINCH_API_BASE=https://api.1inch.dev

# =============================================================================
# MARKET DATA APIs
# =============================================================================

# CoinMarketCap
COINMARKETCAP_API_KEY=your_cmc_api_key_here
COINMARKETCAP_API_BASE=https://pro-api.coinmarketcap.com/v1

# CoinGecko
COINGECKO_API_KEY=your_coingecko_api_key_here
COINGECKO_API_BASE=https://pro-api.coingecko.com/api/v3

# CryptoCompare
CRYPTOCOMPARE_API_KEY=your_cryptocompare_key_here

# =============================================================================
# ANALYTICS APIs
# =============================================================================

# Dune Analytics
DUNE_API_KEY=your_dune_api_key_here
DUNE_API_BASE=https://api.dune.com/api/v1

# Nansen (wallet analytics)
NANSEN_API_KEY=your_nansen_api_key_here

# Arkham Intelligence
ARKHAM_API_KEY=your_arkham_api_key_here

# =============================================================================
# EXCHANGE APIs (for CEX arbitrage)
# =============================================================================

# Binance
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true  # Set to false for production

# Bybit
BYBIT_API_KEY=your_bybit_api_key_here
BYBIT_API_SECRET=your_bybit_api_secret_here
BYBIT_TESTNET=true

# Coinbase Pro
COINBASE_API_KEY=your_coinbase_key_here
COINBASE_API_SECRET=your_coinbase_secret_here
COINBASE_PASSPHRASE=your_coinbase_passphrase_here

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# Encryption key for encrypting private keys in storage
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# Keystore directory (where encrypted keys are stored)
KEYSTORE_DIR=./keystore

# Maximum transaction size (in USD) to prevent fat-finger errors
MAX_TRANSACTION_SIZE_USD=10000

# Whitelist of allowed contract addresses (comma-separated)
# Leave empty to disable
ALLOWED_CONTRACTS=

# Emergency stop - set to true to halt all trading
EMERGENCY_STOP=false

# =============================================================================
# LOGGING & MONITORING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Slack webhook for alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram bot for alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Discord webhook for alerts
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# =============================================================================
# PERFORMANCE TUNING
# =============================================================================

# RPC request timeout (seconds)
RPC_TIMEOUT=30

# Maximum concurrent requests
MAX_CONCURRENT_REQUESTS=10

# Cache duration for market data (seconds)
CACHE_DURATION=60

# Priority fee for Solana (micro-lamports per CU)
SOLANA_PRIORITY_FEE=10000

# Gas price multiplier for Ethereum (1.0 = market rate)
ETH_GAS_MULTIPLIER=1.1

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Use testnet instead of mainnet
USE_TESTNET=true

# Testnet RPC URLs
SOLANA_DEVNET_RPC=https://api.devnet.solana.com
ETHEREUM_GOERLI_RPC=https://eth-goerli.g.alchemy.com/v2/YOUR_KEY
BASE_GOERLI_RPC=https://base-goerli.g.alchemy.com/v2/YOUR_KEY

# Faucet private keys (for testing only - no real funds)
TEST_WALLET_PRIVATE_KEY_SOLANA=your_devnet_wallet_key_here
TEST_WALLET_PRIVATE_KEY_ETHEREUM=0x_your_goerli_wallet_key_here
